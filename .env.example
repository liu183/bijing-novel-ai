# ============================================================================
# 笔境 AI - 环境变量配置模板
# 复制此文件为 .env.local 并填入实际值
# ============================================================================

# Nvidia NIM API Key (必填)
# 获取地址: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# 默认模型（可选，不设置则使用 nvidia/llama-3.1-nemotron-ultra-253b-instruct）
# NVIDIA_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-instruct

# ============================================================================
# 数据库配置
# ============================================================================

# 本地开发使用 SQLite:
DATABASE_URL=file:./db/custom.db

# Vercel 部署 — 在 Vercel Dashboard > Storage 中创建 Postgres 后自动注入:
# POSTGRES_PRISMA_URL=postgresql://user:password@host/database?pgbouncer=true&sslmode=require
# POSTGRES_URL=postgresql://user:password@host/database?sslmode=require
# POSTGRES_URL_NON_POOLING=postgresql://user:password@host/database?sslmode=require
# DATABASE_URL  (通常等于 POSTGRES_PRISMA_URL)
