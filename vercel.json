{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npx prisma generate --schema=prisma/schema.postgres.prisma && npx next build",
  "installCommand": "npm install --ignore-scripts && npx prisma generate --schema=prisma/schema.postgres.prisma",
  "outputDirectory": ".next",
  "git": {
    "deploymentEnabled": true
  }
}
