// ============================================================================
// 笔境 AI - Database Schema for PostgreSQL (Vercel / Supabase)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Novel {
  id          String   @id @default(cuid())
  title       String
  genre       String   @default("未分类")
  subgenre    String   @default("")
  style       String   @default("爽文")
  targetWords Int      @default(50000)
  description String   @default("")
  status      String   @default("draft")
  currentStep Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps    NovelStep[]
  chapters Chapter[]
  messages ChatMessage[]
  activities AgentActivity[]

  @@index([status])
}

model NovelStep {
  id         String   @id @default(cuid())
  novelId    String
  stepNumber Int
  title      String
  content    String   @default("")
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([novelId, stepNumber])
  @@index([novelId])
}

model Chapter {
  id        String   @id @default(cuid())
  novelId   String
  number    Int
  title     String   @default("")
  content   String   @default("")
  wordCount Int      @default(0)
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([novelId, number])
  @@index([novelId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  novelId   String
  role      String
  content   String
  stepRef   Int?
  agentId   String?
  agentName String?
  skillUsed String?
  createdAt DateTime @default(now())

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@index([novelId])
  @@index([createdAt])
}

model AgentActivity {
  id               String   @id @default(cuid())
  novelId          String
  agentId          String
  agentName        String
  type             String
  content          String   @default("")
  skillName        String?
  skillDescription String?
  status           String?
  metadata         String   @default("{}")
  createdAt        DateTime @default(now())

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@index([novelId])
  @@index([createdAt])
}
